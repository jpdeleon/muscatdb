# muscat-db + prose2 environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) and edit. muscat-db auto-loads `.env` on import
# (see src/muscat_db/__init__.py); the canonical registry is src/muscat_db/config.py.
#
# muscat-db spawns prose2 as a subprocess that INHERITS this environment, so
# defining a variable here covers GUI/cron-launched jobs automatically.
#
# For MANUAL prose2 runs in the conda `prose` shell, load the same file first:
#     set -a; source .env; set +a
# (or add it to the conda env's etc/conda/activate.d/).
#
# Values shown are the in-code defaults; uncomment only what you need to override.

# --- paths ---------------------------------------------------------------------
# MUSCAT_DB_PATH=muscat.db                       # SQLite database path
# MUSCAT_DATA_DIR=/data/MuSCAT                    # raw FITS data base dir (no default)
# MUSCAT_PROSE_DIR=/ut2/jerome/ql/prose          # pipeline output base
# MUSCAT_PROSE_PROJECT=../ext_tools/prose2       # prose2 repo path
# MUSCAT_PROSE_PYTHON=                           # explicit prose interpreter (optional, highest priority)
# MUSCAT_PROSE_CONDA_ENV=prose                   # conda env supplying prose deps
# MUSCAT_TIMER_DIR=/ut2/jerome/ql/timer          # timer package output dir

# --- temp ----------------------------------------------------------------------
# Route ephemerals off the small root /tmp onto raid (avoids ENOSPC during
# astropy mmap probes / FITS I/O). Applied to spawned jobs via _job_env().
MUSCAT_TMPDIR=/raid_ut2/home/jerome/tmp

# --- photometry job lifecycle (seconds) ---------------------------------------
# MUSCAT_PHOT_STALL_LIMIT_S=1500                 # kill a job idle this long
# MUSCAT_PHOT_MAX_RUNTIME_S=10800                # hard runtime cap
# MUSCAT_PHOT_FINALIZE_GRACE_S=8                 # log-quiescence grace before terminal

# --- secrets -------------------------------------------------------------------
# Astrometry.net key for prose2 nova WCS solving. Only needed for muscat/muscat2
# calibration with --wcs_method nova. NOT needed if you use --wcs_method twirl
# (twirl+Gaia, no key), nor for BANZAI-reduced muscat3/muscat4/sinistro.
# ASTROMETRY_NET_API_KEY=
