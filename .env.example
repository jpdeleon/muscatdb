# muscat-db + prose2 environment configuration
# -----------------------------------------------------------------------------
# Copy to `.env` (gitignored) and edit. muscat-db auto-loads `.env` on import
# (see src/muscat_db/__init__.py); the canonical registry is src/muscat_db/config.py.
#
# muscat-db spawns prose2 as a subprocess that INHERITS this environment, so
# defining a variable here covers GUI/cron-launched jobs automatically.
#
# For MANUAL prose2 runs in the conda `prose` shell, load the same file first:
#     set -a; source .env; set +a
# (or add it to the conda env's etc/conda/activate.d/).
#
# Values shown are the in-code defaults; uncomment only what you need to override.

# --- paths ---------------------------------------------------------------------
# MUSCAT_DB_PATH=muscat.db                       # SQLite database path
# MUSCAT_DATA_DIR=/data/MuSCAT                    # raw FITS data base dir (no default)
# MUSCAT_OBSLOG_DIR=/ut3/muscat/obslog           # shared obslog CSV base (muscat-db + prose2)
# MUSCAT_PROSE_DIR=/ut2/jerome/ql/prose          # pipeline output base
# MUSCAT_PROSE_PROJECT=../ext_tools/prose2       # prose2 repo path
# MUSCAT_PROSE_PYTHON=                           # explicit prose interpreter (optional, highest priority)
# MUSCAT_PROSE_CONDA_ENV=prose                   # conda env supplying prose deps
# MUSCAT_TIMER_DIR=/ut2/jerome/ql/timer          # timer package output dir
#
# >>> celery + redis multi-server migration <<<
# MUSCAT_PROSE_DIR and MUSCAT_TIMER_DIR are OUTPUT DATA dirs (web app reads
# products from them, daily cron writes to them); MUSCAT_OBSLOG_DIR and
# MUSCAT_DATA_DIR are shared INPUT dirs (obslog CSVs / raw FITS, read by every
# worker). Across multiple worker hosts these MUST all resolve to ONE shared
# location reachable by every worker AND the web host -- otherwise workers read
# from / scatter results to local disks the GUI can't see. So during migration:
#   - Point them at a shared mount (NFS / shared raid), e.g.
#       MUSCAT_PROSE_DIR=/shared/muscat/ql/prose
#       MUSCAT_TIMER_DIR=/shared/muscat/ql/timer
#       MUSCAT_OBSLOG_DIR=/shared/muscat/obslog
#       MUSCAT_DATA_DIR=/shared/muscat/data
#     and set them IDENTICALLY in every node's env (this file, or a shared env
#     sourced by the celery workers and the web host). MUSCAT_OBSLOG_DIR is read
#     by BOTH muscat-db and prose2, so a single value keeps them in sync.
#   - Do NOT derive these from $HOME / Path.home(): each worker's home differs,
#     which fragments inputs/outputs. Use an explicit absolute shared path.
#   - MUSCAT_TMPDIR is the OPPOSITE: keep it per-host/local (fast local scratch,
#     not shared) -- see the temp section below.

# --- temp ----------------------------------------------------------------------
# Route ephemerals off the small root /tmp onto a roomy disk (avoids ENOSPC
# during astropy mmap probes / FITS I/O). Applied to spawned jobs via _job_env().
# Default (resolved in code): $HOME/.muscatdb/tmp, via Path.home() so it works
# even when $HOME is unset (cron/systemd workers). Override below only if home is
# on a small/full filesystem. NOTE: dotenv does NOT expand '~'; use an absolute
# path or ${HOME:-...}. A bare ${HOME} would collapse to /.muscatdb/tmp (the full
# root disk) when $HOME is unset, and would override the safe code default -- so
# the :- fallback below is mandatory if you uncomment this.
# MUSCAT_TMPDIR=${HOME:-/raid_ut2/home/jerome}/.muscatdb/tmp

# --- photometry job lifecycle (seconds) ---------------------------------------
# MUSCAT_PHOT_STALL_LIMIT_S=1500                 # kill a job idle this long
# MUSCAT_PHOT_MAX_RUNTIME_S=10800                # hard runtime cap
# MUSCAT_PHOT_FINALIZE_GRACE_S=8                 # log-quiescence grace before terminal

# --- secrets -------------------------------------------------------------------
# Astrometry.net key for prose2 nova WCS solving. Only needed for muscat/muscat2
# calibration with --wcs_method nova. NOT needed if you use --wcs_method twirl
# (twirl+Gaia, no key), nor for BANZAI-reduced muscat3/muscat4/sinistro.
# ASTROMETRY_NET_API_KEY=

# LCO Observation Portal API token, used by the /lco page for the IPP dry-run and
# (later) live request submission. Server-side only; never exposed to the browser.
# Find yours at https://observe.lco.global/accounts/profile/ .
# LCO_API_TOKEN=

# --- LCO downloads -------------------------------------------------------------
# Root for LCO archive frame downloads, laid out as <root>/<instrument>/<date>/.
# When unset, falls back to MUSCAT_DATA_DIR's per-instrument layout.
# MUSCAT_LCO_DIR=/data/lco
